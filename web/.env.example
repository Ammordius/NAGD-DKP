# Copy to .env.local and fill in from Supabase → Settings → API
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Optional: hosted class_rankings.json (Magelo export) for officer bid forecast live upgrade fallback.
# Same artifact as GitHub secret CLASS_RANKINGS_URL for CI bid_forecast_items shards.
# VITE_CLASS_RANKINGS_URL=https://example.com/path/class_rankings.json

# Set to false to hide "Sign up" on login (invite-only; also disable signups in Supabase Auth).
# VITE_ALLOW_SIGNUP=false

# Optional: for estimate_backup_size.py (full row counts under RLS). Do not commit if set.
# VITE_SUPABASE_SERVICE_ROLE_KEY=eyJ...
